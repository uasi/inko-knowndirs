    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Apple,
        Strategy.PreferXdg,
      )

      t.equal(app.config_directory, Path.new('/home/user/.config/myapp'))
    },
  )

  t.test(
    'EntryLocator.config_directory returns the XDG config entry subdirectory for (Xdg, PreferNative)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Xdg,
        Strategy.PreferNative,
      )

      t.equal(app.config_directory, Path.new('/home/user/.config/myapp'))
    },
  )

  t.test(
    'EntryLocator.config_directory returns the XDG config entry subdirectory for (Xdg, PreferXdg)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Xdg,
        Strategy.PreferXdg,
      )

      t.equal(app.config_directory, Path.new('/home/user/.config/myapp'))
    },
  )

  t.test(
    'EntryLocator.state_directory returns the Apple Application Support entry subdirectory for (Apple, PreferNative)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Apple,
        Strategy.PreferNative,
      )

      t.equal(
        app.state_directory,
        Path.new('/home/user/Library/Application Support/MyApp'),
      )
    },
  )

  t.test(
    'EntryLocator.state_directory returns the XDG state entry subdirectory for (Apple, PreferXdg)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Apple,
        Strategy.PreferXdg,
      )

      t.equal(app.state_directory, Path.new('/home/user/.local/state/myapp'))
    },
  )

  t.test(
    'EntryLocator.state_directory returns the XDG state entry subdirectory for (Xdg, PreferNative)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Xdg,
        Strategy.PreferNative,
      )

      t.equal(app.state_directory, Path.new('/home/user/.local/state/myapp'))
    },
  )

  t.test(
    'EntryLocator.state_directory returns the XDG state entry subdirectory for (Xdg, PreferXdg)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Xdg,
        Strategy.PreferXdg,
      )

      t.equal(app.state_directory, Path.new('/home/user/.local/state/myapp'))
    },
  )

  t.test(
    'EntryLocator.cache_directory returns the Apple Caches entry subdirectory for (Apple, PreferNative)',
    fn (t) {
      let app = entry(
        [('HOME', '/home/user')],
        Platform.Apple,
        Strategy.PreferNative,
      )

      t.equal(app.cache_directory, Path.new('/home/user/Library/Caches/MyApp'))
